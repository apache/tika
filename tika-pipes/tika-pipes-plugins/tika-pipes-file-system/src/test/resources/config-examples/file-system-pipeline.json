{
  "fetchers": {
    "input-fetcher": {
      "file-system-fetcher": {
        "basePath": "/data/input",
        "extractFileSystemMetadata": true
      }
    }
  },
  "emitters": {
    "output-emitter": {
      "file-system-emitter": {
        "basePath": "/data/output",
        "fileExtension": "json",
        "onExists": "SKIP",
        "prettyPrint": false
      }
    }
  },
  "parsers": [
    {
      "default-parser": {}
    }
  ]
}
